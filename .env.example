# ── Firebase (client-side — prefix with REACT_APP_) ──────────────────────────
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=

# ── Stripe (server-side only — DO NOT prefix with REACT_APP_) ─────────────────
STRIPE_SECRET_KEY=sk_live_...          # or sk_test_... for testing
STRIPE_WEBHOOK_SECRET=whsec_...        # from Stripe dashboard > Webhooks

# ── Firebase Admin (server-side — for the webhook to write to Firestore) ──────
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── App ───────────────────────────────────────────────────────────────────────
APP_URL=https://your-app.vercel.app   # your production URL (no trailing slash)
